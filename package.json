{
  "name": "emailsdone",
  "version": "0.1.11",
  "description": "Template-first transactional email SDK for EmailsDone.",
  "type": "module",
  "main": "./EmailsDone/dist/index.js",
  "types": "./EmailsDone/dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./EmailsDone/dist/index.d.ts",
      "import": "./EmailsDone/dist/index.js"
    }
  },
  "files": [
    "EmailsDone/dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "emailsdone",
    "email",
    "transactional-email",
    "transactional",
    "email-sdk",
    "password-reset",
    "verification-email",
    "notification-email",
    "ses"
  ],
  "author": "EmailsDone",
  "license": "MIT",
  "homepage": "https://emailsdone.dev/docs/libraries/node/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emailsdone-dev/emailsdone-node.git"
  },
  "bugs": {
    "url": "https://github.com/emailsdone-dev/emailsdone-node/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  }
}
